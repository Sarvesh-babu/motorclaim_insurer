# ── ClaimIntel — API Keys ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys before running docker compose up

# Groq API  (free — https://console.groq.com)
# Powers all 5 agents: text LLM + vision LLM
GROQ_API_KEY=your_groq_key_here

# OpenWeatherMap  (free tier — https://openweathermap.org/api)
# Used by Agent 4 (Context Verification) for live weather at incident location
OPENWEATHERMAP_API_KEY=your_owm_key_here

# ── Live spare-part pricing (optional) ──────────────────────────────────────────
# Enables "from-the-internet" damage cost estimates in Agent 1. Set EITHER one.
# Without a key, the engine uses its built-in segment-aware catalog (still accurate).

# Serper.dev  (free — https://serper.dev — 2,500 Google searches)  [preferred]
SERPER_API_KEY=your_serper_key_here

# Tavily      (free — https://tavily.com — 1,000 searches/month)   [alternative]
TAVILY_API_KEY=your_tavily_key_here

# ── PII encryption at rest ───────────────────────────────────────────────────────
# Encrypts claimant name + phone in claims.csv. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without a key, the app still runs but PII is stored in plaintext.
ENCRYPTION_KEY=
