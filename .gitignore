# ── Secrets (NEVER commit) ────────────────────────────────────────────────────
.env
*.env
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
dist/
dist-ssr/
*.local

# ── Generated data (rebuilt locally) ──────────────────────────────────────────
data/vectorstore/
data/price_cache.json
data/token_usage.csv

# ── Demo media supplied at demo time ──────────────────────────────────────────
# The generated showcase fixtures (PDFs, telematics JSON, *_NEEDED.txt, README)
# are committed; the real photos / dashcam clips dropped into test/ are not.
test/**/*.jpg
test/**/*.jpeg
test/**/*.png
test/**/*.webp
test/**/*.mp4
test/**/*.mov
test/**/*.avi

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.DS_Store
Thumbs.db
*.suo
*.sw?

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
